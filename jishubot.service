[Unit]
Description=HuiYing Ledger Bot Service
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/jishubot
Environment="PATH=/home/ubuntu/jishubot/venv/bin"
ExecStart=/home/ubuntu/jishubot/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
